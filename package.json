{
  "name": "headsdown-claude",
  "version": "0.2.0",
  "description": "HeadsDown availability extension for Claude Code. Gives Claude awareness of your focus mode, schedule, and availability before starting tasks.",
  "type": "module",
  "bin": {
    "headsdown-claude": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk && esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "headsdown",
    "availability",
    "focus",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/headsdownapp/headsdown-claude.git"
  },
  "homepage": "https://github.com/headsdownapp/headsdown-claude#readme",
  "bugs": {
    "url": "https://github.com/headsdownapp/headsdown-claude/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@headsdown/sdk": "git+https://github.com/headsdownapp/headsdown-sdk.git#0dfaf46",
    "@types/node": "^20.17.0",
    "esbuild": "^0.25.11",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
